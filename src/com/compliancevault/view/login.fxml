<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.compliancevault.controller.LoginController"
      alignment="CENTER"
      spacing="14"
      style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="ComplianceVault"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <Label text="Sign in to continue"
           style="-fx-font-size: 13px; -fx-text-fill: #666;"/>

    <VBox spacing="6">
        <Label text="Username"/>
        <TextField fx:id="usernameField" promptText="Enter your username"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="Enter your password"/>
    </VBox>

    <Label fx:id="errorLabel"
           text=""
           style="-fx-text-fill: #c62828; -fx-font-size: 12px;"/>

    <Button fx:id="loginButton"
            text="Sign in"
            onAction="#handleLogin"
            defaultButton="true"
            maxWidth="Infinity"
            style="-fx-background-color: #185FA5; -fx-text-fill: white; -fx-font-weight: bold;"/>

</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.compliancevault.controller.DashboardController"
            style="-fx-background-color: #ffffff;">

    <!-- TOP: header bar with user info + logout -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #185FA5; -fx-padding: 12 20 12 20;">
            <Label text="ComplianceVault"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel"
                   style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-border-color: white; -fx-border-radius: 4;"/>
        </HBox>
    </top>

    <!-- CENTER: summary cards + search + table -->
    <center>
        <VBox spacing="16" style="-fx-padding: 20;">

            <!-- Summary cards -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox fx:id="totalCard" spacing="4"
                      style="-fx-background-color: #f5f5f5; -fx-padding: 14 18 14 18;
                             -fx-background-radius: 8; -fx-min-width: 130;">
                    <Label text="TOTAL SUPPLIERS"
                           style="-fx-font-size: 10px; -fx-text-fill: #666; -fx-font-weight: bold;"/>
                    <Label fx:id="totalCount" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox spacing="4"
                      style="-fx-background-color: #d5f5e3; -fx-padding: 14 18 14 18;
                             -fx-background-radius: 8; -fx-min-width: 130;">
                    <Label text="COMPLIANT"
                           style="-fx-font-size: 10px; -fx-text-fill: #0f6e56; -fx-font-weight: bold;"/>
                    <Label fx:id="compliantCount" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f6e56;"/>
                </VBox>
                <VBox spacing="4"
                      style="-fx-background-color: #fadbd8; -fx-padding: 14 18 14 18;
                             -fx-background-radius: 8; -fx-min-width: 130;">
                    <Label text="NON-COMPLIANT"
                           style="-fx-font-size: 10px; -fx-text-fill: #922b21; -fx-font-weight: bold;"/>
                    <Label fx:id="nonCompliantCount" text="0"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #922b21;"/>
                </VBox>
            </HBox>

            <!-- Search bar -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Search:"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                <TextField fx:id="searchField"
                           promptText="Company name, phone, or service type"
                           HBox.hgrow="ALWAYS"
                           style="-fx-pref-width: 400;"/>
            </HBox>

            <!-- Supplier table -->
            <TableView fx:id="supplierTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="companyColumn" text="Company" prefWidth="200"/>
                    <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="130"/>
                    <TableColumn fx:id="serviceColumn" text="Service Type" prefWidth="150"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>